<% content_for :title, "Log in" %>
<div class="auth card">
  <h1>Log in</h1>
  <%= form_with url: session_path, class: "form" do |form| %>
    <label class="field">Email
      <%= form.email_field :email_address, required: true, autofocus: true,
            autocomplete: "username", value: params[:email_address] %>
    </label>
    <label class="field">Password
      <%= form.password_field :password, required: true,
            autocomplete: "current-password", maxlength: 72 %>
    </label>
    <%= form.submit "Log in", class: "btn btn--primary" %>
  <% end %>
  <p class="muted">
    <%= link_to "Forgot password?", new_password_path %> ·
    <%= link_to "Create an account", new_registration_path %>
  </p>
</div>
