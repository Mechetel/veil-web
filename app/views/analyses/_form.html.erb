<%= form_with url: analyses_path, method: :post, multipart: true, id: "analysis_form", class: "card form" do %>
  <h2>Run a steganalyzer</h2>

  <label class="field">Steganalyzer
    <%= select_tag :analyzer_key, options_for_select(analyzer_options), prompt: "— choose a detector —", required: true %>
  </label>

  <%= render "shared/image_source" %>

  <%= submit_tag "Analyze", class: "btn btn--primary" %>
<% end %>
