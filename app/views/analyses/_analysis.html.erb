<%= tag.div id: dom_id(analysis), class: "record record--#{analysis.status}" do %>
  <header class="record__head">
    <%= link_to "Analysis ##{analysis.id}", analysis_path(analysis), class: "record__title" %>
    <span class="record__head-right">
      <%= status_badge(analysis) %>
      <%= delete_link(url: analysis_path(analysis), label: "✕", css: "record__del",
            title: "Delete this analysis?", message: "This permanently removes the analysis.") %>
    </span>
  </header>

  <div class="record__meta"><span class="muted"><%= analysis.analyzer_key %></span></div>

  <div class="record__body">
    <% if analysis.in_flight? %>
      <span class="spinner" aria-label="Processing"></span>
    <% elsif analysis.succeeded? %>
      <p>
        <strong class="verdict verdict--<%= analysis.label %>"><%= analysis.label&.titleize %></strong>
        <span class="muted">p(stego) = <%= number_with_precision(analysis.prob_stego.to_f, precision: 3) %></span>
      </p>
      <div class="prob-bar"><span style="width: <%= (analysis.prob_stego.to_f * 100).round %>%"></span></div>
    <% elsif analysis.failed? %>
      <p class="error"><%= analysis.error_message %></p>
    <% end %>
  </div>
<% end %>
