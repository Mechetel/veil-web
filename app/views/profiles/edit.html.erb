<% content_for :title, "Edit profile" %>

<div class="auth card">
  <h1>Edit profile</h1>
  <% if @user.errors.any? %><div class="error"><%= @user.errors.full_messages.to_sentence %></div><% end %>
  <%= form_with model: @user, url: profile_path, method: :patch, class: "form" do |f| %>
    <label class="field">Username
      <%= f.text_field :username, autocomplete: "username", placeholder: "optional display name" %>
    </label>
    <%= f.submit "Save", class: "btn btn--primary" %>
  <% end %>
</div>

<div class="auth card">
  <h2>Change password</h2>
  <%= form_with url: password_change_path, method: :patch, class: "form" do %>
    <label class="field">Current password
      <%= password_field_tag :current_password, nil, required: true, autocomplete: "current-password" %>
    </label>
    <label class="field">New password
      <%= password_field_tag :password, nil, required: true, autocomplete: "new-password", maxlength: 72 %>
    </label>
    <label class="field">Confirm new password
      <%= password_field_tag :password_confirmation, nil, required: true, autocomplete: "new-password", maxlength: 72 %>
    </label>
    <%= submit_tag "Change password", class: "btn btn--primary" %>
  <% end %>
  <p class="muted"><%= link_to "← Back to profile", profile_path %></p>
</div>
