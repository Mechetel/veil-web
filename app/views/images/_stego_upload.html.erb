<%= form_with url: images_path, method: :post, multipart: true, id: "stego_upload", class: "card form" do %>
  <h3>Add stego images</h3>
  <%= hidden_field_tag :kind, "stego" %>
  <label class="field">Created with model
    <%= select_tag :model_key, options_for_select(steg_model_options), include_blank: "— model (optional) —" %>
  </label>
  <%= render "shared/file_field", name: "images[]", multiple: true, required: true %>
  <%= submit_tag "Add to gallery", class: "btn btn--primary" %>
<% end %>
