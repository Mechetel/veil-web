<% content_for :title, "Analyses · Image ##{@image.id}" %>
<%= turbo_stream_from Current.user, "analyses" %>

<div class="detail">
  <%= link_to "← Image ##{@image.id}", image_path(@image), class: "btn" %>

  <div class="detail__meta">
    <h2>Steganalyses of image #<%= @image.id %></h2>
    <span class="badge badge--<%= @image.kind %>"><%= @image.kind %></span>
    <span class="muted"><%= image_meta(@image.file) %></span>
  </div>

  <figure class="detail__image">
    <%= image_tag @image.file, class: "detail__img" %>
  </figure>

  <%# Run more analyses on this very image, any time. The create response
      prepends the new rows + refreshes the count — no reload needed. %>
  <%= form_with url: analyses_path, method: :post, id: "image_analysis_form", class: "card form detail__form" do %>
    <h3>Run another analysis</h3>
    <%= hidden_field_tag :image_id, @image.id %>
    <label class="field">Steganalyzer — a prepared group or a single detector
      <%= select_tag :analyzer_key, analyzer_select_options, prompt: "— choose —", required: true %>
    </label>
    <%= submit_tag "Analyze", class: "btn btn--primary" %>
  <% end %>

  <div class="detail__form" data-controller="bulk-select">
    <%= form_with url: bulk_destroy_analyses_path, method: :post, id: "image_analysis_bulk_form",
          data: { action: "turbo:submit-end->bulk-select#reset" } do %><% end %>

    <%= render "analyses/count_heading", image: @image %>

    <div class="bulk-bar">
      <label><%= check_box_tag "row_select_all", "1", false,
            data: { action: "bulk-select#toggleAll", "bulk-select-target": "selectAll" } %> Select all</label>
      <span class="muted" data-bulk-select-target="count">0 selected</span>
      <span class="bulk-bar__actions" data-bulk-select-target="actions" hidden>
        <%= delete_link(url: bulk_destroy_analyses_path, method: "post", form: "image_analysis_bulk_form",
              label: "Delete selected", title: "Delete selected analyses?",
              message: "The selected analyses will be permanently deleted.") %>
      </span>
      <span class="bulk-bar__spacer"></span>
    </div>

    <div id="<%= dom_id(@image, :all_analyses) %>" class="analysis-rows analysis-rows--full">
      <%= render partial: "analyses/selectable_row", collection: @analyses, as: :analysis %>
    </div>
  </div>
</div>
