<% content_for :title, "Gallery" %>
<h1>Gallery</h1>

<%# Tabs are turbo-frame navigations: the frame targets _top (image links, forms
    and downloads inside behave like normal page navigation), while the tab
    links stay in the frame and advance the URL. %>
<%= turbo_frame_tag "gallery_tabs", target: "_top" do %>
  <nav class="tabs__nav">
    <% { "cover" => "Covers", "stego" => "Stegos" }.each do |key, label| %>
      <%= link_to label, images_path(tab: key),
            class: "tabs__btn #{'is-active' if @tab == key}",
            data: { turbo_frame: "gallery_tabs", turbo_action: "advance" } %>
    <% end %>
  </nav>

  <section class="tabs__panel">
    <%= render "images/count", kind: @tab %>
    <%= render "images/#{@tab}_upload" %>
    <%= render "images/collection", kind: @tab, images: @images, pagy: @images_pagy %>
  </section>
<% end %>
