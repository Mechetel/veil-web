<% content_for :title, "Veil Studio" %>

<%# Tabs are turbo-frame navigations: the frame targets _top (links/forms inside
    behave like normal page navigation), while the tab links explicitly stay in
    the frame and advance the URL — only the active tab's data is loaded. %>
<%= turbo_frame_tag "studio_tabs", target: "_top" do %>
  <nav class="tabs__nav">
    <% { "encode" => "Encode", "decode" => "Decode", "analyze" => "Analyze" }.each do |key, label| %>
      <%= link_to label, root_path(tab: key),
            class: "tabs__btn #{'is-active' if @tab == key}",
            data: { turbo_frame: "studio_tabs", turbo_action: "advance" } %>
    <% end %>
  </nav>

  <section class="tabs__panel">
    <%= render "dashboard/#{@tab}_tab" %>
  </section>
<% end %>
