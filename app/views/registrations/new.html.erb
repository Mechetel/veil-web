<% content_for :title, "Sign up" %>
<div class="auth card">
  <h1>Create your account</h1>
  <% if @user.errors.any? %>
    <div class="error"><%= @user.errors.full_messages.to_sentence %></div>
  <% end %>
  <%= form_with url: registration_path, class: "form" do |form| %>
    <label class="field">Email
      <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username" %>
    </label>
    <label class="field">Password
      <%= form.password_field :password, required: true, autocomplete: "new-password", maxlength: 72 %>
    </label>
    <label class="field">Confirm password
      <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password", maxlength: 72 %>
    </label>
    <%= form.submit "Sign up", class: "btn btn--primary" %>
  <% end %>
  <p class="muted">Already have an account? <%= link_to "Log in", new_session_path %></p>
</div>
