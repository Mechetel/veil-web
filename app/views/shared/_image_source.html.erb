<%# Choose an image: upload a new file (with preview), pick one of your images,
    or pick a shared default (public/default_images). `kinds` filters the
    gallery picker (encode→cover, decode→stego, analyze→both). %>
<% kinds = local_assigns[:kinds] %>
<% picker_images = Current.user.images.then { |s| kinds ? s.where(kind: kinds) : s }.gallery.with_attached_file.limit(100) %>
<% default_names = DefaultImages.all %>

<fieldset class="image-source" data-controller="image-source">
  <legend>Image</legend>

  <div class="image-source__modes">
    <label><input type="radio" name="image_mode" value="upload" checked
                  data-action="image-source#choose"> Upload</label>
    <label><input type="radio" name="image_mode" value="gallery"
                  data-action="image-source#choose"> From my images</label>
    <label><input type="radio" name="image_mode" value="defaults"
                  data-action="image-source#choose"> Defaults</label>
  </div>

  <div data-image-source-target="upload" class="image-source__panel">
    <label class="file-field__label">
      <%= file_field_tag :image, accept: "image/png,image/jpeg", class: "file-field__input",
            data: { "image-source-target": "fileInput", action: "image-source#previewFile" } %>
      <span class="file-field__cta"><span class="file-field__icon">⬆</span>
        <strong>Click to choose</strong> or drop an image
        <span class="muted">(PNG/JPG, max 2 MB)</span></span>
    </label>
    <span class="error" data-image-source-target="error" hidden></span>
  </div>

  <div data-image-source-target="gallery" class="image-source__panel" hidden>
    <%= render "shared/image_picker", images: picker_images %>
  </div>

  <div data-image-source-target="defaults" class="image-source__panel" hidden>
    <% if default_names.any? %>
      <div class="picker">
        <% default_names.each do |name| %>
          <label class="picker__item">
            <%= radio_button_tag :default_image, name, false,
                  data: { action: "image-source#previewSelected", "preview-url": "/default_images/#{name}" } %>
            <span class="picker__thumb"><%= image_tag "/default_images/#{name}", loading: "lazy", alt: name %></span>
            <span class="picker__meta"><%= name %></span>
          </label>
        <% end %>
      </div>
      <p class="muted">Using a default copies it into your gallery.</p>
    <% else %>
      <p class="muted">No default images available.</p>
    <% end %>
  </div>

  <figure class="image-source__preview" data-image-source-target="previewWrap" hidden>
    <figcaption class="muted">Selected image</figcaption>
    <img data-image-source-target="preview" alt="Selected image preview">
  </figure>
</fieldset>
